# GitHub token for fetching roadmap data.
# Create at: https://github.com/settings/tokens
# Required scopes: read:org, read:project
GITHUB_TOKEN=

# Optional: Discovery mode - dump project schema to public/config/roadmap-schema.json
# Set FETCH_ROADMAP_DISCOVER=true to run discovery (then update scripts/roadmap-field-mapping.json)
FETCH_ROADMAP_DISCOVER=false

# Optional: AI summarization via AWS Bedrock
# Set FETCH_ROADMAP_SUMMARIZE=true to enable
FETCH_ROADMAP_SUMMARIZE=false

# Optional: Custom prompt file (e.g. public/config/summarize-prompt.txt for PUBSEC/DOD focus)
# SUMMARIZE_PROMPT_FILE=public/config/summarize-prompt.txt

# Bedrock model ID (e.g. anthropic.claude-3-haiku-20240307-v1:0)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# AWS region for Bedrock (e.g. us-east-1)
AWS_REGION=us-east-1
# AWS credentials (or use ~/.aws/credentials / IAM role)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
