# GitHub token for fetching roadmap data.
# Create at: https://github.com/settings/tokens
# Required scopes: read:org, read:project
GITHUB_TOKEN=

# Optional: AI summarization via AWS Bedrock
# Set FETCH_ROADMAP_SUMMARIZE=true to enable
FETCH_ROADMAP_SUMMARIZE=false
# Bedrock model ID (e.g. anthropic.claude-3-haiku-20240307-v1:0)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# AWS region for Bedrock (e.g. us-east-1)
AWS_REGION=us-east-1
# AWS credentials (or use ~/.aws/credentials / IAM role)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
